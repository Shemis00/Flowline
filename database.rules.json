{
  "rules": {
    ".read": false,
    ".write": false,
    "boards": {
      "$boardId": {
        ".read": true,
        "columns": {
          ".write": "data.val() === null",
          "$columnId": {
            ".write": true,
            ".validate": "newData.hasChildren(['title', 'order'])",
            "title": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
            },
            "order": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "cards": {
          "$cardId": {
            ".write": true,
            ".validate": "newData.hasChildren(['title', 'columnId', 'order', 'createdAt'])",
            "title": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
            },
            "description": {
              ".validate": "newData.isString() && newData.val().length <= 2000"
            },
            "dueDate": {
              ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)"
            },
            "assigneeId": { ".validate": "newData.isString()" },
            "columnId": { ".validate": "newData.isString()" },
            "order": { ".validate": "newData.isNumber()" },
            "createdAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "members": {
          "$memberId": {
            ".write": true,
            ".validate": "newData.hasChildren(['name', 'createdAt'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60"
            },
            "createdAt": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    }
  }
}
